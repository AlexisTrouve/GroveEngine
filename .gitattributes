# Normalise line endings on commit; checkout uses platform native endings
* text=auto

# Force LF for shell scripts and CMake files
*.sh text eol=lf
*.cmake text eol=lf
CMakeLists.txt text eol=lf

# Force CRLF for Windows-specific files
*.bat text eol=crlf
*.cmd text eol=crlf

# Large raster assets via Git LFS — kept out of the git object history.
# NOTE: images committed BEFORE LFS was adopted (e.g. existing textures) stay as
# regular git blobs; migrating them would require rewriting already-pushed history
# (force-push), so it's deliberately not done here. New/modified raster files go to LFS.
*.png  filter=lfs diff=lfs merge=lfs -text
*.jpg  filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.bmp  filter=lfs diff=lfs merge=lfs -text

# Other binary assets (no line-ending conversion, not LFS)
*.gif binary
*.ico binary
*.dll binary
*.so binary
*.a binary
*.lib binary
*.exe binary
