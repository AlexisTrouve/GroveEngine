      "style": { "normal": { "bgColor": "0x2aa5b8FF", "textColor": "0xFFFFFFFF" }, "hover": { "bgColor": "0x4fd3e6FF" }, "pressed": { "bgColor": "0x1b6f7cFF" } } },

    { "type": "label", "id": "lblAnim", "x": 40, "y": 240, "text": "Auto-anime (la largeur pulse — le cadre reste continu, sans seam) :", "fontSize": 15, "style": { "textColor": "0xb9c4d4FF" } },
    { "type": "button", "id": "b_anim", "x": 40, "y": 268, "width": 200, "height": 46, "text": "Pulse",
