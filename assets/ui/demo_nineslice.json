      ] },

    { "type": "window", "id": "winPlain", "x": 720, "y": 480, "width": 300, "height": 160, "title": "Fenetre PLATE (contraste)",
      "style": { "bgColor": "0x1a2230F0", "titleBarColor": "0x2a3a52FF", "titleColor": "0xFFFFFFFF" },
      "children": [
        { "type": "label", "id": "winTxt2", "x": 16, "y": 16, "text": "Fond plein, pas de cadre compose.", "fontSize": 14, "style": { "textColor": "0xcdd6e4FF" } }
