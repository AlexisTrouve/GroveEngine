    { "type": "label", "id": "title", "x": 40, "y": 24, "text": "9-slice — bordures composees (bord continu a toute taille)", "fontSize": 24, "style": { "textColor": "0xE8EEF7FF" } },
    { "type": "label", "id": "hint", "x": 40, "y": 58, "text": "Les cadres sont UNE texture 9-slicee. Survole les boutons (re-teinte), etire les fenetres (drag coin) — les coins restent nets.", "fontSize": 14, "style": { "textColor": "0x8b98acFF" } },

    { "type": "label", "id": "lblBtns", "x": 40, "y": 100, "text": "Boutons framed — memes 32x32, tailles differentes :", "fontSize": 15, "style": { "textColor": "0xb9c4d4FF" } },

    { "type": "button", "id": "b_small", "x": 40,  "y": 128, "width": 90,  "height": 40, "text": "Petit",
      "frame": { "asset": "ui_btn_frame", "srcW": 32, "srcH": 32, "inset": 10 },
      "style": { "normal": { "bgColor": "0x2aa5b8FF", "textColor": "0xFFFFFFFF" }, "hover": { "bgColor": "0x4fd3e6FF" }, "pressed": { "bgColor": "0x1b6f7cFF" } } },

    { "type": "button", "id": "b_norm", "x": 150, "y": 128, "width": 170, "height": 40, "text": "Normal",
