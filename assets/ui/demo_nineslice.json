      "style": { "normal": { "bgColor": "0xe0a83cFF", "textColor": "0x1a1206FF" }, "hover": { "bgColor": "0xffca63FF" }, "pressed": { "bgColor": "0xb2812aFF" } } },

    { "type": "label", "id": "lblFlat", "x": 40, "y": 340, "text": "Contraste — bouton PLAT (borderColor/borderWidth, pas de cadre) :", "fontSize": 15, "style": { "textColor": "0xb9c4d4FF" } },
    { "type": "button", "id": "b_flat", "x": 40, "y": 368, "width": 200, "height": 44, "text": "Plat",
