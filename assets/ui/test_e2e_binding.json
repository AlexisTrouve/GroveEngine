{
  "id": "root",
  "type": "panel",
  "x": 0,
  "y": 0,
  "width": 800,
  "height": 600,
  "children": [
    {
      "id": "creditsLbl",
      "type": "label",
      "x": 20,
      "y": 20,
      "text": "Credits: {{credits}}",
      "fontSize": 16
    },
    {
      "id": "goBtn",
      "type": "button",
      "x": 20,
      "y": 60,
      "width": 100,
      "height": 30,
      "text": "Go",
      "onClick": "legacy:go",
      "on": {
        "click": {
          "event": "act:launch",
          "args": { "who": "{{commander}}", "fleet": "{{fleet}}" }
        }
      }
    }
  ]
}
