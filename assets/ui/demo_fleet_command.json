{
  "id": "root",
  "type": "panel",
  "x": 0, "y": 0, "width": 1280, "height": 720,
  "style": { "bgColor": "0x10141cFF" },
  "children": [

    {
      "id": "hud",
      "type": "panel",
      "x": 0, "y": 0, "width": 1280, "height": 44,
      "style": { "bgColor": "0x1b2230FF" },
      "children": [
        { "type": "label", "x": 16, "y": 12, "width": 320, "height": 24, "text": "GROVE — Fleet Command", "style": { "fontSize": 18, "color": "0xFFFFFFFF" } },
        { "type": "label", "x": 380, "y": 14, "width": 160, "height": 20, "text": "Crédits: {{credits}}", "style": { "fontSize": 15, "color": "0x9fe6a0FF" } },
        { "type": "label", "x": 560, "y": 14, "width": 110, "height": 20, "text": "Tour {{turn}}", "style": { "fontSize": 15, "color": "0xbcd0ffFF" } },
        { "type": "label", "x": 680, "y": 14, "width": 150, "height": 20, "text": "Vaisseaux: {{fleetCount}}", "style": { "fontSize": 15, "color": "0xbcd0ffFF" } },
        { "id": "btnTurn", "type": "button", "x": 860, "y": 8, "width": 90, "height": 30, "text": "Tour +",
          "on": { "click": { "event": "turn:advance" } },
          "style": { "normal": {"bgColor":"0x2e7d32FF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0x388e3cFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1b5e20FF","textColor":"0xFFFFFFFF"} } },
        { "id": "btnJournal", "type": "button", "x": 960, "y": 8, "width": 100, "height": 30, "text": "Journal",
          "on": { "click": { "event": "demo:drawer", "args": { "id": "journal" } } },
          "style": { "normal": {"bgColor":"0x37474fFF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0x455a64FF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x263238FF","textColor":"0xFFFFFFFF"} } }
      ]
    },

    {
      "id": "fleet",
      "type": "list",
      "x": 16, "y": 60, "width": 300, "height": 640,
      "rowHeight": 56,
      "repeat": "{{fleet}}",
      "style": { "bgColor": "0x141a26FF", "scrollbarColor": "0x4a6da5FF", "scrollbarTrackColor": "0x0c0f16FF" },
      "template": {
        "type": "panel",
        "x": 0, "y": 0, "width": 300, "height": 56,
        "style": { "bgColor": "0x1b2433FF" },
        "children": [
          { "type": "label", "x": 12, "y": 8, "width": 200, "height": 20, "text": "{{name}}", "style": { "fontSize": 16, "color": "0xFFFFFFFF" } },
          { "type": "label", "x": 12, "y": 30, "width": 160, "height": 16, "text": "{{cls}}", "style": { "fontSize": 11, "color": "0x8fa3c4FF" } },
          { "type": "progressbar", "x": 150, "y": 34, "width": 134, "height": 8, "value": "{{hp}}", "style": { "bgColor": "0x0c0f16FF", "fillColor": "0x39b54aFF" } },
          { "type": "button", "x": 0, "y": 0, "width": 300, "height": 56, "text": "",
            "on": { "click": { "event": "fleet:select", "args": { "id": "{{id}}" } } },
            "style": { "normal": {"bgColor":"0x00000000","textColor":"0x00000000"}, "hover": {"bgColor":"0x2a3850A0","textColor":"0x00000000"}, "pressed": {"bgColor":"0x3a558aA0","textColor":"0x00000000"} } }
        ]
      }
    },

    {
      "id": "detailWin",
      "type": "window",
      "x": 340, "y": 70, "width": 440, "height": 320,
      "title": "Détail vaisseau",
      "draggable": true, "resizable": true, "closable": true,
      "style": { "bgColor": "0x1b2230FF", "titleBarColor": "0x2a3346FF" },
      "children": [
        { "type": "label", "x": 16, "y": 12, "width": 360, "height": 28, "text": "{{selected.name}}", "style": { "fontSize": 22, "color": "0xFFFFFFFF" } },
        { "type": "label", "x": 16, "y": 46, "width": 360, "height": 20, "text": "Classe: {{selected.cls}}", "style": { "fontSize": 14, "color": "0x9fb0c4FF" } },
        { "type": "label", "x": 16, "y": 78, "width": 80, "height": 20, "text": "Coque", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } },
        { "type": "progressbar", "x": 16, "y": 100, "width": 360, "height": 16, "value": "{{selected.hp}}", "style": { "bgColor": "0x0c0f16FF", "fillColor": "0x39b54aFF" } },
        { "id": "hintNone", "type": "label", "x": 16, "y": 150, "width": 360, "height": 24, "if": "{{noSelection}}", "text": "← Sélectionne un vaisseau dans la flotte", "style": { "fontSize": 14, "color": "0xf2c94cFF" } },
        { "id": "scuttleBtn", "type": "button", "x": 16, "y": 150, "width": 160, "height": 34, "if": "{{hasSelection}}", "text": "Saborder",
          "on": { "click": { "event": "demo:modalOpen", "args": { "id": "scuttleModal" } } },
          "style": { "normal": {"bgColor":"0xb23b3bFF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0xcf4b4bFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x8e2e2eFF","textColor":"0xFFFFFFFF"} } }
      ]
    },

    {
      "id": "sections",
      "type": "tabs",
      "x": 800, "y": 70, "width": 464, "height": 320,
      "tabBarHeight": 32,
      "tabs": [ { "label": "Aperçu" }, { "label": "Stats" }, { "label": "Aide" } ],
      "style": { "bgColor": "0x141a26FF", "activeTabColor": "0x3a6ea5FF", "inactiveTabColor": "0x232c3aFF" },
      "children": [
        { "type": "panel", "x": 0, "y": 0, "width": 464, "height": 288, "style": { "bgColor": "0x00000000" },
          "children": [
            { "type": "label", "x": 16, "y": 16, "width": 420, "height": 24, "text": "Flotte: {{fleetCount}} vaisseaux, {{credits}} crédits", "style": { "fontSize": 15, "color": "0xFFFFFFFF" } },
            { "type": "label", "x": 16, "y": 50, "width": 420, "height": 60, "text": "Liaison données ↔ UI : tout ce panneau est bindé.\nClique un vaisseau, avance le tour : ça suit.", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } }
          ] },
        { "type": "panel", "x": 0, "y": 0, "width": 464, "height": 288, "style": { "bgColor": "0x00000000" },
          "children": [
            { "type": "label", "x": 16, "y": 16, "width": 420, "height": 24, "text": "Sélection: {{selected.name}}", "style": { "fontSize": 15, "color": "0xFFFFFFFF" } },
            { "type": "label", "x": 16, "y": 48, "width": 420, "height": 20, "text": "Classe {{selected.cls}}", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } }
          ] },
        { "type": "panel", "x": 0, "y": 0, "width": 464, "height": 288, "style": { "bgColor": "0x00000000" },
          "children": [
            { "type": "label", "x": 16, "y": 16, "width": 430, "height": 120, "text": "Clic vaisseau = sélection.\nTour + = +1 tour & usure de coque (live).\nJournal = tiroir bas.\nClic droit = roue d'action.", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } }
          ] }
      ]
    },

    {
      "id": "journal",
      "type": "drawer",
      "edge": "bottom",
      "openExtent": 150,
      "open": false,
      "style": { "bgColor": "0x161d2aFF" },
      "children": [
        { "type": "label", "x": 24, "y": 16, "width": 400, "height": 24, "text": "Journal de bord", "style": { "fontSize": 18, "color": "0xFFFFFFFF" } },
        { "type": "label", "x": 24, "y": 50, "width": 800, "height": 80, "text": "Tour courant: {{turn}} — Crédits: {{credits}} — Flotte: {{fleetCount}}\n(tiroir piloté par un event déclaratif relayé par le jeu)", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } }
      ]
    },

    {
      "id": "scuttleModal",
      "type": "modal",
      "visible": false,
      "dialogWidth": 380, "dialogHeight": 180,
      "style": { "dimColor": "0x000000B0", "dialogColor": "0x232c3aFF" },
      "children": [
        { "type": "label", "x": 24, "y": 24, "width": 330, "height": 28, "text": "Saborder {{selected.name}} ?", "style": { "fontSize": 18, "color": "0xFFFFFFFF" } },
        { "type": "label", "x": 24, "y": 58, "width": 330, "height": 20, "text": "Action irréversible.", "style": { "fontSize": 13, "color": "0xf2c94cFF" } },
        { "type": "button", "x": 24, "y": 110, "width": 150, "height": 38, "text": "Confirmer",
          "on": { "click": { "event": "fleet:scuttle", "args": { "id": "{{selected.id}}" } } },
          "style": { "normal": {"bgColor":"0xb23b3bFF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0xcf4b4bFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x8e2e2eFF","textColor":"0xFFFFFFFF"} } },
        { "type": "button", "x": 200, "y": 110, "width": 150, "height": 38, "text": "Annuler",
          "on": { "click": { "event": "demo:modalClose", "args": { "id": "scuttleModal" } } },
          "style": { "normal": {"bgColor":"0x37474fFF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0x455a64FF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x263238FF","textColor":"0xFFFFFFFF"} } }
      ]
    },

    {
      "id": "wheel",
      "type": "radial",
      "x": 640, "y": 400,
      "innerRadius": 48, "outerRadius": 150,
      "visible": false,
      "items": [
        { "action": "act:move", "text": "Move" },
        { "action": "act:attack", "text": "Attack" },
        { "action": "act:hold", "text": "Hold" },
        { "action": "act:scan", "text": "Scan" }
      ],
      "style": { "bgColor": "0x000000C0", "itemColor": "0x34495eFF", "hoverColor": "0x2ecc71FF", "textColor": "0xFFFFFFFF", "fontSize": 15 }
    }

  ]
}
