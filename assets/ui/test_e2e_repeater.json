{
  "id": "root",
  "type": "panel",
  "x": 0,
  "y": 0,
  "width": 800,
  "height": 600,
  "children": [
    {
      "id": "fleetList",
      "type": "panel",
      "x": 100,
      "y": 100,
      "width": 220,
      "height": 400,
      "repeat": "{{fleet}}",
      "template": {
        "type": "panel",
        "x": 0,
        "y": 0,
        "width": 220,
        "height": 40,
        "children": [
          { "type": "label", "x": 4, "y": 10, "text": "{{name}}", "fontSize": 14 },
          {
            "type": "button",
            "x": 160, "y": 4, "width": 50, "height": 32,
            "text": "X",
            "on": { "click": { "event": "fleet:recall", "args": { "shipId": "{{id}}" } } }
          }
        ]
      }
    }
  ]
}
