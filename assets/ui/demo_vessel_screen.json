{
  "id": "root",
  "type": "panel",
  "x": 0, "y": 0, "width": 1280, "height": 720,
  "widthPercent": 1.0, "heightPercent": 1.0,
  "style": { "bgColor": "0x0a0e16FF" },
  "children": [
    {
      "id": "hud",
      "type": "panel",
      "x": 0, "y": 0, "widthPercent": 1.0, "height": 44,
      "style": { "bgColor": "0x121822FF" },
      "children": [
        {
          "id": "btnFleet", "type": "button", "x": 12, "y": 7, "width": 120, "height": 30, "text": "Flotte",
          "on": { "click": { "event": "vessel:drawer" } },
          "style": {
            "normal":  { "bgColor": "0x2a3346FF", "textColor": "0xeaf0f8FF" },
            "hover":   { "bgColor": "0x3a4a63FF", "textColor": "0xFFFFFFFF" },
            "pressed": { "bgColor": "0x1f2736FF", "textColor": "0xFFFFFFFF" }
          }
        }
      ]
    },

    {
      "id": "fleetPanel",
      "type": "panel",
      "x": 12, "y": 52, "width": 252, "height": 214,
      "visible": false,
      "style": { "bgColor": "0x121824F8" },
      "children": [
        {
          "id": "grpLabels",
          "type": "panel",
          "x": 10, "y": 8, "width": 234, "height": 200,
          "style": { "bgColor": "0x00000000" },
          "repeat": "{{groups}}",
          "template": {
            "type": "label", "x": 0, "y": "{{ly}}", "width": 200, "height": 16,
            "text": "{{name}}", "style": { "fontSize": 12, "color": "0x8fa6c8FF" }
          }
        },
        {
          "id": "fleetIcons",
          "type": "panel",
          "x": 10, "y": 8, "width": 234, "height": 200,
          "style": { "bgColor": "0x00000000" },
          "repeat": "{{slots}}",
          "template": {
            "type": "button",
            "x": "{{ix}}", "y": "{{iy}}", "width": 40, "height": 40,
            "texture": "{{icon}}", "text": "",
            "on": { "click": { "event": "vessel:open", "args": { "id": "{{id}}" } } },
            "style": {
              "normal":  { "bgColor": "0x1b2433FF", "borderColor": "0x2a3650FF", "borderWidth": 1 },
              "hover":   { "bgColor": "0x243150FF", "borderColor": "0xffd166FF", "borderWidth": 2 },
              "pressed": { "bgColor": "0x161d2aFF", "borderColor": "0xffffffFF", "borderWidth": 2 }
            }
          }
        }
      ]
    }
  ]
}
