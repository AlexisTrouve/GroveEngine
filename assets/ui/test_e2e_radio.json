{
  "id": "root",
  "type": "panel",
  "x": 0,
  "y": 0,
  "width": 800,
  "height": 600,
  "children": [
    {
      "id": "now_playing",
      "type": "label",
      "x": 20,
      "y": 20,
      "width": 300,
      "height": 30,
      "text": "{{radio.title}}"
    },
    {
      "id": "play_btn",
      "type": "button",
      "x": 20,
      "y": 60,
      "width": 100,
      "height": 30,
      "text": "Play",
      "on": {
        "click": {
          "event": "sound:music",
          "args": { "path": "music/track1.ogg" }
        }
      }
    },
    {
      "id": "stop_btn",
      "type": "button",
      "x": 20,
      "y": 100,
      "width": 100,
      "height": 30,
      "text": "Stop",
      "on": {
        "click": {
          "event": "sound:music:stop"
        }
      }
    },
    {
      "id": "progress",
      "type": "progressbar",
      "x": 20,
      "y": 140,
      "width": 300,
      "height": 20,
      "value": "{{radio.progress}}"
    }
  ]
}
