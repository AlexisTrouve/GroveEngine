{
  "id": "root",
  "type": "panel",
  "x": 0, "y": 0, "width": 1280, "height": 720,
  "widthPercent": 1.0, "heightPercent": 1.0,
  "style": { "bgColor": "0x0e1118FF" },
  "children": [
    {
      "id": "inspector",
      "type": "window",
      "widthPercent": 0.62, "heightPercent": 0.82,
      "anchor": "center",
      "title": "Inspecteur vaisseau",
      "draggable": true, "resizable": true, "closable": true,
      "style": { "bgColor": "0x161d2aFF", "titleBarColor": "0x2a3346FF" },
      "children": [
        {
          "id": "body",
          "type": "panel",
          "widthPercent": 1.0, "heightPercent": 1.0,
          "layout": { "type": "vertical", "spacing": 8, "padding": 10 },
          "style": { "bgColor": "0x00000000" },
          "children": [
            { "type": "label", "widthPercent": 1.0, "height": 26, "text": "{{ship.name}}", "style": { "fontSize": 20, "color": "0xFFFFFFFF" } },
            {
              "id": "split",
              "type": "panel",
              "widthPercent": 1.0,
              "layout": { "type": "horizontal", "spacing": 10, "flex": 1 },
              "style": { "bgColor": "0x00000000" },
              "children": [
                {
                  "id": "blueprint",
                  "type": "panel",
                  "heightPercent": 1.0,
                  "layout": { "flex": 1 },
                  "style": { "bgColor": "0x0b1018FF" },
                  "repeat": "{{ship.parts}}",
                  "template": {
                    "type": "button",
                    "x": "{{x}}", "y": "{{y}}", "width": "{{w}}", "height": "{{h}}",
                    "color": "{{color}}", "texture": "{{tex}}", "text": "",
                    "on": { "click": { "event": "ship:part", "args": { "id": "{{id}}", "label": "{{label}}", "stat": "{{stat}}" } } },
                    "style": {
                      "normal":  { "borderColor": "0x0b1018FF", "borderWidth": 1 },
                      "hover":   { "borderColor": "0xffd166FF", "borderWidth": 2 },
                      "pressed": { "borderColor": "0xffffffFF", "borderWidth": 2 }
                    }
                  }
                },
                {
                  "id": "side",
                  "type": "panel",
                  "width": 240, "heightPercent": 1.0,
                  "layout": { "type": "vertical", "spacing": 8, "padding": 8, "flex": 0 },
                  "style": { "bgColor": "0x10182aFF" },
                  "children": [
                    {
                      "id": "info",
                      "type": "panel",
                      "widthPercent": 1.0, "height": 150,
                      "style": { "bgColor": "0x00000000" },
                      "children": [
                        { "type": "label", "x": 6, "y": 4,   "width": 210, "height": 22, "text": "Piece", "style": { "fontSize": 13, "color": "0x6f86a8FF" } },
                        { "type": "label", "x": 6, "y": 28,  "width": 210, "height": 24, "text": "{{selectedPart.label}}", "style": { "fontSize": 18, "color": "0xFFFFFFFF" } },
                        { "type": "label", "x": 6, "y": 64,  "width": 210, "height": 60, "text": "{{selectedPart.stat}}", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } },
                        { "id": "partHint", "type": "label", "x": 6, "y": 118, "width": 210, "height": 40, "if": "{{noPart}}", "text": "Clique une piece", "style": { "fontSize": 13, "color": "0xf2c94cFF" } }
                      ]
                    },
                    {
                      "id": "resources",
                      "type": "list",
                      "widthPercent": 1.0,
                      "layout": { "flex": 1 },
                      "rowHeight": 32,
                      "style": {
                        "bgColor": "0x0b1220FF",
                        "headerColor": "0x24314aFF", "headerLabelColor": "0xFFFFFFFF",
                        "rowColor": "0x161f2eFF", "rowAltColor": "0x121a27FF",
                        "labelColor": "0xeaf0f8FF", "subtitleColor": "0x8fa0b8FF",
                        "fontSize": 13, "subtitleFontSize": 10,
                        "scrollbarColor": "0x5a6b80FF", "scrollbarTrackColor": "0x10141cFF"
                      }
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
