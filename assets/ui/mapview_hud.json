{
  "id": "root",
  "type": "panel",
  "x": 0, "y": 0, "width": 1280, "height": 720,
  "style": { "bgColor": "0x00000000" },
  "comment": "Root is transparent so the pannable/zoomable map shows through; all widgets are screen-fixed HUD (retained HUD bucket).",
  "children": [

    {
      "id": "catbar",
      "type": "panel",
      "x": 0, "y": 0, "width": 1280, "height": 40,
      "style": { "bgColor": "0x141a26E0" },
      "comment": "Category bar (top). Fixed set from the viewer's categorization table; each button emits cat:select. Elevation returns to terrain.",
      "children": [
        { "id": "catElev", "type": "button", "x": 1130, "y": 6, "width": 120, "height": 28, "text": "Élévation",
          "comment": "Right end so the open LEFT resource drawer never occludes this mode-reset button.",
          "on": { "click": { "event": "lens:terrain" } },
          "style": { "normal": {"bgColor":"0x2e7d32FF","textColor":"0xFFFFFFFF"}, "hover": {"bgColor":"0x388e3cFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1b5e20FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catFuel",  "type": "button", "x": 136,  "y": 6, "width": 130, "height": 28, "text": "Combustibles",
          "on": { "click": { "event": "cat:select", "args": { "id": "Combustibles" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catMetal", "type": "button", "x": 274,  "y": 6, "width": 110, "height": 28, "text": "Métaux",
          "on": { "click": { "event": "cat:select", "args": { "id": "Métaux" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catPrec",  "type": "button", "x": 392,  "y": 6, "width": 110, "height": 28, "text": "Précieux",
          "on": { "click": { "event": "cat:select", "args": { "id": "Précieux" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catRad",   "type": "button", "x": 510,  "y": 6, "width": 120, "height": 28, "text": "Radioactifs",
          "on": { "click": { "event": "cat:select", "args": { "id": "Radioactifs" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catIce",   "type": "button", "x": 638,  "y": 6, "width": 150, "height": 28, "text": "Glaces & volatils",
          "on": { "click": { "event": "cat:select", "args": { "id": "Glaces&volatils" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catMin",   "type": "button", "x": 796,  "y": 6, "width": 110, "height": 28, "text": "Minéraux",
          "on": { "click": { "event": "cat:select", "args": { "id": "Minéraux" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } },
        { "id": "catOther", "type": "button", "x": 914,  "y": 6, "width": 100, "height": 28, "text": "Autres",
          "on": { "click": { "event": "cat:select", "args": { "id": "Autres" } } },
          "style": { "normal": {"bgColor":"0x232c3aFF","textColor":"0xd6e2ffFF"}, "hover": {"bgColor":"0x2f3b4eFF","textColor":"0xFFFFFFFF"}, "pressed": {"bgColor":"0x1a2130FF","textColor":"0xFFFFFFFF"} } }
      ]
    },

    {
      "id": "resDrawer",
      "type": "drawer",
      "edge": "left",
      "openExtent": 240,
      "open": false,
      "style": { "bgColor": "0x141a26F0" },
      "comment": "Resource sub-menu (left). Populated at runtime by the viewer via ui:list:set_items from the clicked category. A row click emits ui:list:selected -> the viewer swaps to that resource's density heatmap lens.",
      "children": [
        { "type": "label", "x": 16, "y": 48, "width": 210, "height": 22, "text": "{{catTitle}}", "style": { "fontSize": 15, "color": "0xFFFFFFFF" } },
        { "id": "resList", "type": "list", "x": 8, "y": 76, "width": 224, "height": 620, "rowHeight": 30,
          "style": { "bgColor": "0x0e1420FF", "scrollbarColor": "0x4a6da5FF", "scrollbarTrackColor": "0x0c0f16FF" } }
      ]
    },

    {
      "id": "corePanel",
      "type": "panel",
      "x": 1000, "y": 52, "width": 272, "height": 380,
      "style": { "bgColor": "0x1b2230F0" },
      "comment": "Planet CORE panel (right). Non-spatial planet state from the core.json side-car, pushed via ui:data {core:{...}}. Composition rows are hoverable (tooltip = material / quantity / %).",
      "children": [
        { "type": "label", "x": 16, "y": 12, "width": 240, "height": 26, "text": "Noyau", "style": { "fontSize": 18, "color": "0xFFFFFFFF" } },
        { "type": "label", "x": 16, "y": 46, "width": 240, "height": 20, "text": "Température: {{core.temperature_c}} °C", "style": { "fontSize": 13, "color": "0xf2a25cFF" } },
        { "type": "label", "x": 16, "y": 70, "width": 240, "height": 20, "text": "Capacité: {{core.max_capacity}}", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } },
        { "type": "label", "x": 16, "y": 94, "width": 240, "height": 20, "text": "Masse: {{core.total_mass}}", "style": { "fontSize": 13, "color": "0x9fb0c4FF" } },
        { "type": "label", "x": 16, "y": 122, "width": 120, "height": 18, "text": "Remplissage", "style": { "fontSize": 12, "color": "0x9fb0c4FF" } },
        { "type": "progressbar", "x": 16, "y": 142, "width": 240, "height": 16, "value": "{{core.fill_ratio}}", "style": { "bgColor": "0x0c0f16FF", "fillColor": "0xe0803cFF" } },
        { "type": "label", "x": 16, "y": 172, "width": 240, "height": 18, "text": "Composition", "style": { "fontSize": 13, "color": "0xFFFFFFFF" } },
        { "id": "compList", "type": "list", "x": 8, "y": 196, "width": 256, "height": 176, "rowHeight": 26,
          "repeat": "{{core.composition}}",
          "style": { "bgColor": "0x0e1420FF", "scrollbarColor": "0x4a6da5FF", "scrollbarTrackColor": "0x0c0f16FF" },
          "template": {
            "type": "panel", "x": 0, "y": 0, "width": 256, "height": 26, "style": { "bgColor": "0x1b2433FF" },
            "children": [
              { "type": "label", "x": 10, "y": 5, "width": 150, "height": 16, "text": "{{material}}", "style": { "fontSize": 12, "color": "0xd6e2ffFF" } },
              { "type": "label", "x": 168, "y": 5, "width": 80, "height": 16, "text": "{{fractionPct}}%", "style": { "fontSize": 12, "color": "0x9fe6a0FF" } },
              { "type": "button", "x": 0, "y": 0, "width": 256, "height": 26, "text": "",
                "tooltip": "{{material}} — {{quantity}} ({{fractionPct}}%)",
                "on": { "click": { "event": "core:pick", "args": { "material": "{{material}}" } } },
                "style": { "normal": {"bgColor":"0x00000000","textColor":"0x00000000"}, "hover": {"bgColor":"0x2a3850A0","textColor":"0x00000000"}, "pressed": {"bgColor":"0x3a558aA0","textColor":"0x00000000"} } }
            ]
          }
        }
      ]
    }

  ]
}
