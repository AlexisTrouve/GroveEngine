              "id": "feature_buttons",
              "text": "Buttons",
              "checked": true,
              "style": {
                "fontSize": 12.0
              }
            },
            {
              "type": "checkbox",
              "id": "feature_sliders",
              "text": "Sliders",
              "checked": true,
              "style": {
                "fontSize": 12.0
              }
            },
            {
              "type": "checkbox",
              "id": "feature_text",
