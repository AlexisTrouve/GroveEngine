            "fontSize": 32.0,
            "color": "0xFFFFFFFF"
          }
        },
        {
          "type": "label",
          "text": "All widgets below are interactive. Hover for tooltips!",
          "style": {
            "fontSize": 14.0,
            "color": "0x95a5a6FF"
          }
        },
        {
          "type": "panel",
