                    "fontSize": 16.0,
                    "normal": {
                      "bgColor": "0xc0392bFF",
                      "textColor": "0xFFFFFFFF"
                    },
                    "hover": {
                      "bgColor": "0xe74c3cFF",
                      "textColor": "0xFFFFFFFF"
                    },
                    "pressed": {
                      "bgColor": "0x922b21FF",
                      "textColor": "0xFFFFFFFF"
