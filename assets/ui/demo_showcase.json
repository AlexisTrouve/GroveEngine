                  "max": 100.0,
                  "value": 75.0,
                  "width": 500,
                  "height": 25,
                  "onChange": "settings:volume"
                }
              ]
            },
            {
              "type": "panel",
              "layout": {
                "type": "horizontal",
                "spacing": 10
              },
              "children": [
                {
                  "type": "label",
                  "text": "Brightness:",
                  "tooltip": "Screen brightness",
                  "style": {
                    "fontSize": 16.0,
                    "color": "0xecf0f1FF"
                  }
